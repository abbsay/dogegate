#!/usr/bin/env bash
set -euo pipefail

VERSION="0.3.1"

usage() {
  cat <<'USAGE'
codex-ccswitch-antigravity

Patch CC Switch so Codex Desktop/CLI can route through an Antigravity Pool
OpenAI Responses-compatible gateway.

Usage:
  codex-ccswitch-antigravity install [options]
  codex-ccswitch-antigravity install-openclaw [options]
  codex-ccswitch-antigravity install-hermes [options]
  codex-ccswitch-antigravity verify  [options]
  codex-ccswitch-antigravity verify-agents [options]
  codex-ccswitch-antigravity open-openclaw-dashboard [options]
  codex-ccswitch-antigravity inspect-antigravity [options]
  codex-ccswitch-antigravity doctor  [options]

Options:
  --provider-name NAME       CC Switch Codex provider name (default: Antigravity-Pool)
  --model MODEL              Codex model name (default: claude-sonnet-4-6)
  --pool-models CSV          Pool model ids exposed to agents and pickers
  --agent-models CSV         Pool model ids allowed for OpenClaw agent sessions
  --no-auto-antigravity      Do not read Antigravity Tools config or /v1/models
  --proxy-url URL            CC Switch local proxy URL (default: http://127.0.0.1:15721/v1)
  --upstream-url URL         Antigravity Pool upstream URL (default: http://127.0.0.1:8045/v1)
  --ccswitch-db PATH         CC Switch sqlite database (default: ~/.cc-switch/cc-switch.db)
  --codex-config PATH        Codex live config (default: ~/.codex/config.toml)
  --settings-json PATH       CC Switch settings.json (default: ~/.cc-switch/settings.json)
  --backup-dir PATH          Backup directory (default: ~/.cc-switch/backups/codex-antigravity)
  --no-live-config           Do not patch ~/.codex/config.toml
  --no-select-provider       Do not mark provider current in CC Switch DB
  --no-preserve-codex-auth   Do not enable CC Switch Codex official auth preservation
  --restart-ccswitch         Restart CC Switch after install
  --run-verify               Run Codex verification after install
  --dry-run                  Show planned changes without writing
  -h, --help                 Show this help

Examples:
  codex-ccswitch-antigravity install --restart-ccswitch --run-verify
  codex-ccswitch-antigravity install-openclaw
  codex-ccswitch-antigravity install-hermes
  codex-ccswitch-antigravity verify-agents
  codex-ccswitch-antigravity open-openclaw-dashboard
  codex-ccswitch-antigravity inspect-antigravity
  codex-ccswitch-antigravity doctor
USAGE
}

die() {
  echo "error: $*" >&2
  exit 1
}

expand_path() {
  local p="$1"
  case "$p" in
    "~") printf '%s\n' "$HOME" ;;
    \~/*) printf '%s/%s\n' "$HOME" "${p#\~/}" ;;
    *) printf '%s\n' "$p" ;;
  esac
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

COMMAND="${1:-}"
if [[ "$COMMAND" == "--version" ]]; then
  echo "$VERSION"
  exit 0
fi
if [[ -z "$COMMAND" || "$COMMAND" == "-h" || "$COMMAND" == "--help" ]]; then
  usage
  exit 0
fi
shift || true

PROVIDER_NAME="Antigravity-Pool"
MODEL="claude-sonnet-4-6"
POOL_MODELS="claude-sonnet-4-6,gemini-3.1-pro-high,gemini-3.1-pro-low,gemini-3-flash-agent,gemini-3-flash,gemini-3.5-flash-low,gemini-3.1-flash-image,gpt-oss-120b-medium,claude-3-5-sonnet-20241022"
AGENT_MODELS="claude-sonnet-4-6,gemini-3-flash-agent,gemini-3-flash,gemini-3.5-flash-low,claude-3-5-sonnet-20241022"
PROXY_URL="http://127.0.0.1:15721/v1"
UPSTREAM_URL="http://127.0.0.1:8045/v1"
CCSWITCH_DB="~/.cc-switch/cc-switch.db"
CODEX_CONFIG="~/.codex/config.toml"
SETTINGS_JSON="~/.cc-switch/settings.json"
BACKUP_DIR="~/.cc-switch/backups/codex-antigravity"
PATCH_LIVE_CONFIG=1
SELECT_PROVIDER=1
RESTART_CCSWITCH=0
RUN_VERIFY=0
DRY_RUN=0
AUTO_ANTIGRAVITY=1
PRESERVE_CODEX_AUTH=1
POOL_MODELS_SET=0
UPSTREAM_URL_SET=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --provider-name) PROVIDER_NAME="${2:?}"; shift 2 ;;
    --model) MODEL="${2:?}"; shift 2 ;;
    --pool-models) POOL_MODELS="${2:?}"; POOL_MODELS_SET=1; shift 2 ;;
    --agent-models) AGENT_MODELS="${2:?}"; shift 2 ;;
    --proxy-url) PROXY_URL="${2:?}"; shift 2 ;;
    --upstream-url) UPSTREAM_URL="${2:?}"; UPSTREAM_URL_SET=1; shift 2 ;;
    --ccswitch-db) CCSWITCH_DB="${2:?}"; shift 2 ;;
    --codex-config) CODEX_CONFIG="${2:?}"; shift 2 ;;
    --settings-json) SETTINGS_JSON="${2:?}"; shift 2 ;;
    --backup-dir) BACKUP_DIR="${2:?}"; shift 2 ;;
    --no-live-config) PATCH_LIVE_CONFIG=0; shift ;;
    --no-select-provider) SELECT_PROVIDER=0; shift ;;
    --no-preserve-codex-auth) PRESERVE_CODEX_AUTH=0; shift ;;
    --restart-ccswitch) RESTART_CCSWITCH=1; shift ;;
    --run-verify) RUN_VERIFY=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --no-auto-antigravity) AUTO_ANTIGRAVITY=0; shift ;;
    -h|--help) usage; exit 0 ;;
    --version) echo "$VERSION"; exit 0 ;;
    *) die "unknown option: $1" ;;
  esac
done

CCSWITCH_DB="$(expand_path "$CCSWITCH_DB")"
CODEX_CONFIG="$(expand_path "$CODEX_CONFIG")"
SETTINGS_JSON="$(expand_path "$SETTINGS_JSON")"
BACKUP_DIR="$(expand_path "$BACKUP_DIR")"

sync_antigravity_metadata() {
  [[ "$AUTO_ANTIGRAVITY" -eq 1 ]] || return 0
  need_cmd python3
  local result
  if ! result="$(python3 - "$UPSTREAM_URL" "$POOL_MODELS_SET" "$UPSTREAM_URL_SET" "$POOL_MODELS" <<'PY'
import json
import sys
import urllib.request
from pathlib import Path
from urllib.parse import urljoin

fallback_url, pool_models_set, upstream_url_set, configured_pool_models = sys.argv[1:]
pool_models_set = pool_models_set == "1"
upstream_url_set = upstream_url_set == "1"
cfg_path = Path.home() / ".antigravity_tools" / "gui_config.json"
if not cfg_path.exists():
    raise SystemExit(2)

cfg = json.loads(cfg_path.read_text())
proxy = cfg.get("proxy") or {}
port = int(proxy.get("port") or 8045)
api_key = proxy.get("api_key") or ""
upstream_url = fallback_url if upstream_url_set else f"http://127.0.0.1:{port}/v1"
print(f"UPSTREAM_URL={upstream_url}")

if pool_models_set:
    raise SystemExit(0)

headers = {}
if api_key:
    headers["Authorization"] = f"Bearer {api_key}"
req = urllib.request.Request(urljoin(upstream_url.rstrip("/") + "/", "models"), headers=headers)
with urllib.request.urlopen(req, timeout=15) as resp:
    payload = json.loads(resp.read().decode("utf-8"))

seen = set()
models = []
for model_id in configured_pool_models.split(","):
    model_id = model_id.strip()
    if not model_id or model_id in seen:
        continue
    seen.add(model_id)
    models.append(model_id)
for item in payload.get("data", []):
    model_id = item.get("id")
    if not model_id or model_id in seen:
        continue
    seen.add(model_id)
    models.append(model_id)
if not models:
    raise SystemExit(3)
print("POOL_MODELS=" + ",".join(models))
print(f"ANTIGRAVITY_MODEL_COUNT={len(models)}")
PY
)"; then
    echo "antigravity_auto=unavailable; using configured defaults" >&2
    return 0
  fi

  local line key value model_count=""
  while IFS='=' read -r key value; do
    case "$key" in
      UPSTREAM_URL) UPSTREAM_URL="$value" ;;
      POOL_MODELS) POOL_MODELS="$value" ;;
      ANTIGRAVITY_MODEL_COUNT) model_count="$value" ;;
    esac
  done <<<"$result"
  if [[ -n "$model_count" ]]; then
    echo "antigravity_auto=models:$model_count"
  else
    echo "antigravity_auto=config"
  fi
}

doctor() {
  need_cmd python3
  [[ -f "$CCSWITCH_DB" ]] || die "CC Switch DB not found: $CCSWITCH_DB"
  python3 - "$CCSWITCH_DB" "$PROVIDER_NAME" "$CODEX_CONFIG" "$SETTINGS_JSON" <<'PY'
import json
import sqlite3
import sys
from pathlib import Path

db_path, provider_name, codex_config, settings_json = sys.argv[1:]
conn = sqlite3.connect(db_path)
provider = conn.execute(
    "select id, is_current, settings_config from providers where app_type='codex' and name=?",
    (provider_name,),
).fetchone()
proxy = conn.execute(
    "select proxy_enabled, enabled, listen_address, listen_port from proxy_config where app_type='codex'"
).fetchone()
backup = conn.execute(
    "select original_config from proxy_live_backup where app_type='codex'"
).fetchone()
conn.close()

def print_interesting_config(prefix: str, cfg: str) -> None:
    print(f"{prefix}_has_custom={'[model_providers.custom]' in cfg}")
    print(f"{prefix}_has_experimental_bearer_token={'experimental_bearer_token' in cfg}")
    print(f"{prefix}_has_proxy_placeholder={'PROXY_MANAGED' in cfg}")
    for line in cfg.splitlines():
        stripped = line.strip()
        if stripped.startswith(("model_provider", "model =", "base_url", "wire_api")):
            print(f"{prefix}: {line}")
        elif stripped.startswith("experimental_bearer_token"):
            print(f"{prefix}: experimental_bearer_token = <redacted>")

print(f"ccswitch_db={db_path}")
if Path(settings_json).exists():
    try:
        settings = json.loads(Path(settings_json).read_text())
    except Exception:
        settings = {}
    print(
        "preserve_codex_official_auth_on_switch="
        f"{bool(settings.get('preserveCodexOfficialAuthOnSwitch'))}"
    )
else:
    print(f"settings_json_missing={settings_json}")
print(f"provider_found={bool(provider)}")
if provider:
    cfg = json.loads(provider[2]).get("config", "")
    print(f"provider_id={provider[0]}")
    print(f"provider_is_current={provider[1]}")
    print_interesting_config("provider_config", cfg)
if proxy:
    print(f"proxy_enabled={proxy[0]} enabled={proxy[1]} listen={proxy[2]}:{proxy[3]}")
print(f"live_backup_found={bool(backup)}")
if backup:
    cfg = json.loads(backup[0]).get("config", "")
    print_interesting_config("live_backup", cfg)
if Path(codex_config).exists():
    text = Path(codex_config).read_text()
    print(f"codex_config={codex_config}")
    print_interesting_config("codex_config", text)
else:
    print(f"codex_config_missing={codex_config}")
PY
}

install() {
  need_cmd python3
  [[ -f "$CCSWITCH_DB" ]] || die "CC Switch DB not found: $CCSWITCH_DB"
  sync_antigravity_metadata

  if [[ "$RESTART_CCSWITCH" -eq 1 && "$DRY_RUN" -eq 0 ]]; then
    pkill -f '/Applications/CC Switch.app/Contents/MacOS/cc-switch' >/dev/null 2>&1 || true
    sleep 1
  fi

  if [[ "$DRY_RUN" -eq 0 ]]; then
    mkdir -p "$BACKUP_DIR"
    local stamp
    stamp="$(date +%Y%m%d-%H%M%S)"
    cp "$CCSWITCH_DB" "$BACKUP_DIR/cc-switch.db.$stamp.bak"
    [[ ! -f "$CODEX_CONFIG" ]] || cp "$CODEX_CONFIG" "$BACKUP_DIR/config.toml.$stamp.bak"
    [[ ! -f "$SETTINGS_JSON" ]] || cp "$SETTINGS_JSON" "$BACKUP_DIR/settings.json.$stamp.bak"
    echo "backup_dir=$BACKUP_DIR"
  fi

  python3 - "$CCSWITCH_DB" "$CODEX_CONFIG" "$SETTINGS_JSON" "$PROVIDER_NAME" "$MODEL" "$POOL_MODELS" "$PROXY_URL" "$UPSTREAM_URL" "$PATCH_LIVE_CONFIG" "$SELECT_PROVIDER" "$PRESERVE_CODEX_AUTH" "$DRY_RUN" <<'PY'
import json
import sqlite3
import sys
from pathlib import Path

(
    db_path,
    codex_config,
    settings_json,
    provider_name,
    model,
    pool_models_csv,
    proxy_url,
    upstream_url,
    patch_live_config,
    select_provider,
    preserve_codex_auth,
    dry_run,
) = sys.argv[1:]
patch_live_config = patch_live_config == "1"
select_provider = select_provider == "1"
preserve_codex_auth = preserve_codex_auth == "1"
dry_run = dry_run == "1"

def normalize_pool_models(raw: str, default_model: str) -> list[str]:
    seen = set()
    models = []
    for item in [default_model, *raw.split(",")]:
        model_id = item.strip()
        if not model_id or model_id in seen:
            continue
        seen.add(model_id)
        models.append(model_id)
    return models

pool_models = normalize_pool_models(pool_models_csv, model)

def read_antigravity_api_key() -> str:
    cfg_path = Path.home() / ".antigravity_tools" / "gui_config.json"
    if not cfg_path.exists():
        return ""
    try:
        cfg = json.loads(cfg_path.read_text())
    except Exception:
        return ""
    token = ((cfg.get("proxy") or {}).get("api_key") or "").strip()
    return token if token.startswith("sk-") else ""

TOP_LEVEL_KEYS = {
    "model_provider",
    "model",
    "review_model",
    "disable_response_storage",
    "base_url",
    "wire_api",
    "experimental_bearer_token",
}

def toml_string(value: str) -> str:
    return json.dumps(value)

def transform_config(text: str, provider_url: str, bearer_token: str = "") -> str:
    lines = text.splitlines()
    kept = []
    current_section = None
    skipping_provider = False
    saw_reasoning = False

    for raw in lines:
        stripped = raw.strip()
        if stripped.startswith("[") and stripped.endswith("]"):
            current_section = stripped
            skipping_provider = stripped == "[model_providers.custom]"
            if skipping_provider:
                continue

        if skipping_provider:
            continue

        if current_section is None and "=" in stripped:
            key = stripped.split("=", 1)[0].strip()
            if key in TOP_LEVEL_KEYS:
                continue
            if key == "model_reasoning_effort":
                saw_reasoning = True

        if stripped.startswith("model_reasoning_effort"):
            saw_reasoning = True
        kept.append(raw)

    header = [
        'model_provider = "custom"',
        f'model = "{model}"',
        f'review_model = "{model}"',
        "disable_response_storage = true",
    ]
    if not saw_reasoning:
        header.append('model_reasoning_effort = "medium"')

    provider = [
        "",
        "[model_providers.custom]",
        f"name = {toml_string(provider_name)}",
        f"base_url = {toml_string(provider_url)}",
        'wire_api = "responses"',
        "request_max_retries = 4",
        "stream_max_retries = 10",
        "stream_idle_timeout_ms = 300000",
    ]
    if bearer_token:
        provider.append(f"experimental_bearer_token = {toml_string(bearer_token)}")

    body = "\n".join(line for line in kept).strip()
    return "\n".join(header) + ("\n" + body if body else "") + "\n" + "\n".join(provider) + "\n"

def extract_provider_token(payload: dict) -> str:
    token = ((payload.get("auth") or {}).get("OPENAI_API_KEY") or "").strip()
    return token if token else ""

conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row
provider = conn.execute(
    "select id, settings_config from providers where app_type='codex' and name=?",
    (provider_name,),
).fetchone()
if not provider:
    raise SystemExit(f"provider not found in CC Switch DB: {provider_name}")

provider_payload = json.loads(provider["settings_config"])
provider_payload["config"] = transform_config(provider_payload.get("config", ""), upstream_url)
antigravity_api_key = read_antigravity_api_key()
if antigravity_api_key:
    auth = provider_payload.setdefault("auth", {})
    auth["OPENAI_API_KEY"] = antigravity_api_key
provider_api_key = antigravity_api_key or extract_provider_token(provider_payload)
provider_payload["modelCatalog"] = {
    "models": [
        {
            "model": model_id,
            "displayName": model_id,
            "contextWindow": 1000000,
        }
        for model_id in pool_models
    ]
}

updates = []
updates.append(("provider.settings_config", provider_payload["config"]))

common = conn.execute("select value from settings where key='common_config_codex'").fetchone()
common_value = transform_config(common["value"] if common else "", proxy_url)
updates.append(("settings.common_config_codex", common_value))

proxy_parts = proxy_url.removeprefix("http://").removeprefix("https://").split("/", 1)[0].rsplit(":", 1)
proxy_host = proxy_parts[0]
proxy_port = int(proxy_parts[1]) if len(proxy_parts) == 2 and proxy_parts[1].isdigit() else 15721

backup = conn.execute("select original_config from proxy_live_backup where app_type='codex'").fetchone()
backup_payload = None
if backup:
    backup_payload = json.loads(backup["original_config"])
    backup_token = provider_api_key if preserve_codex_auth else ""
    backup_payload["config"] = transform_config(
        backup_payload.get("config", ""),
        upstream_url,
        backup_token,
    )
    updates.append(("proxy_live_backup.original_config.config", backup_payload["config"]))

live_text = None
if patch_live_config and Path(codex_config).exists():
    live_token = "PROXY_MANAGED" if preserve_codex_auth else ""
    live_text = transform_config(Path(codex_config).read_text(), proxy_url, live_token)
    updates.append(("codex.live_config", live_text))

if dry_run:
    print("dry_run=true")
    for name, value in updates:
        print(f"--- {name} ---")
        for line in value.splitlines():
            if line.strip().startswith(("model_provider", "model =", "review_model", "base_url", "wire_api", "[model_providers.custom]")):
                print(line)
            elif line.strip().startswith("experimental_bearer_token"):
                print("experimental_bearer_token = <redacted>")
    print(f"provider_auth_update={bool(antigravity_api_key)}")
    print(f"provider_model_catalog_count={len(pool_models)}")
    print(f"proxy_config_update={proxy_host}:{proxy_port}")
    print(f"preserve_codex_official_auth_on_switch={preserve_codex_auth}")
    raise SystemExit(0)

conn.execute(
    "update providers set settings_config=? where app_type='codex' and id=?",
    (json.dumps(provider_payload, ensure_ascii=False), provider["id"]),
)

if select_provider:
    conn.execute("update providers set is_current=0 where app_type='codex'")
    conn.execute("update providers set is_current=1 where app_type='codex' and id=?", (provider["id"],))

if common:
    conn.execute("update settings set value=? where key='common_config_codex'", (common_value,))
else:
    conn.execute("insert into settings(key, value) values('common_config_codex', ?)", (common_value,))

conn.execute(
    """
    insert into proxy_config(app_type, proxy_enabled, enabled, listen_address, listen_port, updated_at)
    values('codex', 1, 1, ?, ?, datetime('now'))
    on conflict(app_type) do update set
      proxy_enabled=1,
      enabled=1,
      listen_address=excluded.listen_address,
      listen_port=excluded.listen_port,
      updated_at=datetime('now')
    """,
    (proxy_host, proxy_port),
)

if backup_payload is not None:
    conn.execute(
        "update proxy_live_backup set original_config=? where app_type='codex'",
        (json.dumps(backup_payload, ensure_ascii=False),),
    )

conn.commit()
conn.close()

if live_text is not None:
    Path(codex_config).write_text(live_text)

settings_path = Path(settings_json)
if select_provider or preserve_codex_auth:
    if settings_path.exists():
        data = json.loads(settings_path.read_text())
    else:
        data = {}
        settings_path.parent.mkdir(parents=True, exist_ok=True)
    if select_provider:
        data["currentProviderCodex"] = provider_name
    if preserve_codex_auth:
        data["preserveCodexOfficialAuthOnSwitch"] = True
    settings_path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n")

print(f"provider={provider_name}")
print(f"model={model}")
print(f"pool_models_count={len(pool_models)}")
print(f"codex_live_proxy={proxy_url}")
print(f"ccswitch_upstream={upstream_url}")
print(f"provider_auth_update={bool(antigravity_api_key)}")
print(f"proxy_config_update={proxy_host}:{proxy_port}")
print(f"preserve_codex_official_auth_on_switch={preserve_codex_auth}")
print("install=ok")
PY

  if [[ "$RESTART_CCSWITCH" -eq 1 && "$DRY_RUN" -eq 0 ]]; then
    open -a 'CC Switch'
    sleep 2
  fi

  if [[ "$RUN_VERIFY" -eq 1 && "$DRY_RUN" -eq 0 ]]; then
    verify
  fi
}

verify() {
  need_cmd codex
  codex --ask-for-approval never --sandbox read-only exec "Reply with exactly: pong"
}

get_pool_token_python='
import json
import sqlite3
import sys

db_path, provider_name = sys.argv[1:]
conn = sqlite3.connect(db_path)
row = conn.execute(
    "select settings_config from providers where app_type=? and name=?",
    ("codex", provider_name),
).fetchone()
conn.close()
if not row:
    raise SystemExit(f"provider not found in CC Switch DB: {provider_name}")
payload = json.loads(row[0])
token = (payload.get("auth") or {}).get("OPENAI_API_KEY") or ""
if not token:
    raise SystemExit(f"provider has no OPENAI_API_KEY token: {provider_name}")
print(token)
'

install_openclaw() {
  need_cmd python3
  [[ -f "$CCSWITCH_DB" ]] || die "CC Switch DB not found: $CCSWITCH_DB"
  sync_antigravity_metadata
  local openclaw_config="$HOME/.openclaw/openclaw.json"
  local openclaw_state="$HOME/.openclaw/agents/main/agent/openclaw-agent.sqlite"
  local openclaw_sessions="$HOME/.openclaw/agents/main/sessions/sessions.json"
  [[ -f "$openclaw_config" ]] || die "OpenClaw config not found: $openclaw_config"
  [[ -f "$openclaw_state" ]] || die "OpenClaw auth state not found: $openclaw_state"

  if [[ "$DRY_RUN" -eq 0 ]]; then
    mkdir -p "$HOME/.openclaw/backups/dogegate"
    local stamp
    stamp="$(date +%Y%m%d-%H%M%S)"
    cp "$openclaw_config" "$HOME/.openclaw/backups/dogegate/openclaw.json.$stamp.bak"
    cp "$openclaw_state" "$HOME/.openclaw/backups/dogegate/openclaw-agent.sqlite.$stamp.bak"
    [[ ! -f "$openclaw_sessions" ]] || cp "$openclaw_sessions" "$HOME/.openclaw/backups/dogegate/sessions.json.$stamp.bak"
    echo "backup_dir=$HOME/.openclaw/backups/dogegate"
  fi

  python3 - "$CCSWITCH_DB" "$PROVIDER_NAME" "$MODEL" "$POOL_MODELS" "$AGENT_MODELS" "$UPSTREAM_URL" "$DRY_RUN" "$openclaw_config" "$openclaw_state" "$openclaw_sessions" <<'PY'
import json
import sqlite3
import sys
import time
from pathlib import Path

db_path, provider_name, model, pool_models_csv, agent_models_csv, upstream_url, dry_run, config_path, state_path, sessions_path = sys.argv[1:]
dry_run = dry_run == "1"

def normalize_pool_models(raw: str, default_model: str) -> list[str]:
    seen = set()
    models = []
    for item in [default_model, *raw.split(",")]:
        model_id = item.strip()
        if not model_id or model_id in seen:
            continue
        seen.add(model_id)
        models.append(model_id)
    return models

pool_models = normalize_pool_models(pool_models_csv, model)
agent_models = normalize_pool_models(agent_models_csv, model)
pool_model_set = set(pool_models)
missing_agent_models = [model_id for model_id in agent_models if model_id not in pool_model_set]
if missing_agent_models:
    raise SystemExit("agent models must be included in pool models: " + ",".join(missing_agent_models))
conn = sqlite3.connect(db_path)
row = conn.execute(
    "select settings_config from providers where app_type='codex' and name=?",
    (provider_name,),
).fetchone()
conn.close()
if not row:
    raise SystemExit(f"provider not found in CC Switch DB: {provider_name}")

def read_antigravity_api_key() -> str:
    cfg_path = Path.home() / ".antigravity_tools" / "gui_config.json"
    if not cfg_path.exists():
        return ""
    try:
        cfg = json.loads(cfg_path.read_text())
    except Exception:
        return ""
    token = ((cfg.get("proxy") or {}).get("api_key") or "").strip()
    return token if token.startswith("sk-") else ""

def extract_provider_token(payload: dict) -> str:
    auth = payload.get("auth") or {}
    token = auth.get("OPENAI_API_KEY")
    return token if isinstance(token, str) and token.startswith("sk-") else ""

token = read_antigravity_api_key() or extract_provider_token(json.loads(row[0]))

cfg_path = Path(config_path)
data = json.loads(cfg_path.read_text())
models = [
    {
        "id": model_id,
        "name": model_id,
        "api": "openai-responses",
        "baseUrl": upstream_url,
        "reasoning": True,
        "input": ["text", "image"],
        "contextWindow": 1000000,
        "contextTokens": 900000,
        "params": {"store": False, "responsesCompactThreshold": 900000},
        "compat": {
            "supportsStore": False,
            "supportsReasoningEffort": True,
            "supportedReasoningEfforts": ["minimal", "low", "medium", "high", "xhigh"],
            "thinkingFormat": "openai",
        },
    }
    for model_id in pool_models
]
provider = data.setdefault("models", {}).setdefault("providers", {}).setdefault("openai", {})
provider.update({
    "baseUrl": upstream_url,
    "auth": "api-key",
    "api": "openai-responses",
    "contextWindow": 1000000,
    "contextTokens": 900000,
    "models": models,
})
primary = f"openai/{model}"
allowed_models = {f"openai/{model_id}": {} for model_id in agent_models}
agent_defaults = data.setdefault("agents", {}).setdefault("defaults", {})
agent_defaults.setdefault("model", {})["primary"] = primary
agent_defaults["models"] = allowed_models
for agent in data.get("agents", {}).get("list", []):
    if "model" in agent:
        agent["model"] = primary
    agent["models"] = allowed_models

sessions_file = Path(sessions_path)
sessions = None
cleared_sessions = 0
override_keys = [
    "modelOverride",
    "providerOverride",
    "modelOverrideSource",
    "authProfileOverride",
    "authProfileOverrideSource",
    "authProfileOverrideCompactionCount",
]
if sessions_file.exists():
    sessions = json.loads(sessions_file.read_text())
    for session in sessions.values():
        if not isinstance(session, dict):
            continue
        provider_override = session.get("providerOverride")
        model_override = session.get("modelOverride")
        if not provider_override and not model_override:
            continue
        selected = f"{provider_override or 'openai'}/{model_override or model}"
        if selected not in allowed_models:
            for key in override_keys:
                session.pop(key, None)
            cleared_sessions += 1

if dry_run:
    print("dry_run=true")
    print(f"openclaw_model={primary}")
    print(f"openclaw_pool_models_count={len(pool_models)}")
    print(f"openclaw_agent_models={','.join(agent_models)}")
    print(f"openclaw_baseUrl={upstream_url}")
    print(f"openclaw_auth_update={bool(token)}")
    print(f"openclaw_session_overrides_to_clear={cleared_sessions}")
    raise SystemExit(0)

cfg_path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n")
if sessions is not None and cleared_sessions:
    sessions_file.write_text(json.dumps(sessions, indent=2, ensure_ascii=False) + "\n")

if token:
    conn = sqlite3.connect(state_path)
    now = int(time.time() * 1000)
    store = {"version": 1, "profiles": {"openai:manual": {"type": "api_key", "provider": "openai", "key": token}}}
    state = {"version": 1, "lastGood": {"openai": "openai:manual"}, "usageStats": {}}
    conn.execute("delete from auth_profile_store where store_key='primary'")
    conn.execute("insert into auth_profile_store(store_key, store_json, updated_at) values('primary', ?, ?)", (json.dumps(store, ensure_ascii=False), now))
    conn.execute("delete from auth_profile_state where state_key='primary'")
    conn.execute("insert into auth_profile_state(state_key, state_json, updated_at) values('primary', ?, ?)", (json.dumps(state, ensure_ascii=False), now))
    conn.commit()
    conn.close()
print(f"openclaw_model={primary}")
print(f"openclaw_pool_models_count={len(pool_models)}")
print(f"openclaw_agent_models={','.join(agent_models)}")
print(f"openclaw_baseUrl={upstream_url}")
print(f"openclaw_auth_update={bool(token)}")
print(f"openclaw_session_overrides_cleared={cleared_sessions}")
print("install_openclaw=ok")
PY
}

install_hermes() {
  need_cmd python3
  [[ -f "$CCSWITCH_DB" ]] || die "CC Switch DB not found: $CCSWITCH_DB"
  sync_antigravity_metadata
  local hermes_config="$HOME/.hermes/config.yaml"
  [[ -f "$hermes_config" ]] || die "Hermes config not found: $hermes_config"

  if [[ "$DRY_RUN" -eq 0 ]]; then
    mkdir -p "$HOME/.hermes/backups/dogegate"
    local stamp
    stamp="$(date +%Y%m%d-%H%M%S)"
    cp "$hermes_config" "$HOME/.hermes/backups/dogegate/config.yaml.$stamp.bak"
    [[ ! -f "$HOME/.hermes/.env" ]] || cp "$HOME/.hermes/.env" "$HOME/.hermes/backups/dogegate/env.$stamp.bak"
    echo "backup_dir=$HOME/.hermes/backups/dogegate"
  fi

  python3 - "$CCSWITCH_DB" "$PROVIDER_NAME" "$MODEL" "$POOL_MODELS" "$UPSTREAM_URL" "$DRY_RUN" "$hermes_config" <<'PY'
import json
import sqlite3
import sys
from pathlib import Path

try:
    import yaml
except Exception as exc:
    raise SystemExit("PyYAML is required for Hermes config editing") from exc

db_path, provider_name, model, pool_models_csv, upstream_url, dry_run, config_path = sys.argv[1:]
dry_run = dry_run == "1"

def normalize_pool_models(raw: str, default_model: str) -> list[str]:
    seen = set()
    models = []
    for item in [default_model, *raw.split(",")]:
        model_id = item.strip()
        if not model_id or model_id in seen:
            continue
        seen.add(model_id)
        models.append(model_id)
    return models

pool_models = normalize_pool_models(pool_models_csv, model)
conn = sqlite3.connect(db_path)
row = conn.execute(
    "select settings_config from providers where app_type='codex' and name=?",
    (provider_name,),
).fetchone()
conn.close()
if not row:
    raise SystemExit(f"provider not found in CC Switch DB: {provider_name}")

def read_antigravity_api_key() -> str:
    cfg_path = Path.home() / ".antigravity_tools" / "gui_config.json"
    if not cfg_path.exists():
        return ""
    try:
        cfg = json.loads(cfg_path.read_text())
    except Exception:
        return ""
    token = ((cfg.get("proxy") or {}).get("api_key") or "").strip()
    return token if token.startswith("sk-") else ""

def extract_provider_token(payload: dict) -> str:
    auth = payload.get("auth") or {}
    token = auth.get("OPENAI_API_KEY")
    return token if isinstance(token, str) and token.startswith("sk-") else ""

token = read_antigravity_api_key() or extract_provider_token(json.loads(row[0]))

cfg_path = Path(config_path)
data = yaml.safe_load(cfg_path.read_text()) or {}
if not token:
    token = (
        (data.get("model") or {}).get("api_key")
        or next(
            (
                provider.get("api_key")
                for provider in (data.get("custom_providers") or [])
                if provider.get("name") == "antigravity-pool" and provider.get("api_key")
            ),
            "",
        )
    )
if not token:
    raise SystemExit(f"provider has no OPENAI_API_KEY token and Hermes has no existing antigravity-pool api_key: {provider_name}")
model_cfg = data.setdefault("model", {})
model_cfg.update({
    "default": model,
    "provider": "custom",
    "base_url": upstream_url,
    "api_key": token,
    "api_mode": "chat_completions",
    "max_tokens": 4096,
})
customs = data.get("custom_providers") or []
customs = [c for c in customs if c.get("name") != "antigravity-pool"]
customs.append({
    "name": "antigravity-pool",
    "base_url": upstream_url,
    "api_key": token,
    "api_mode": "chat_completions",
    "models": {
        model_id: {"context_length": 1000000, "max_completion_tokens": 4096}
        for model_id in pool_models
    },
})
data["custom_providers"] = customs

if dry_run:
    print("dry_run=true")
    print(f"hermes_provider=custom")
    print(f"hermes_model={model}")
    print(f"hermes_pool_models_count={len(pool_models)}")
    print(f"hermes_base_url={upstream_url}")
    print("hermes_max_tokens=4096")
    raise SystemExit(0)

cfg_path.write_text(yaml.safe_dump(data, sort_keys=False, allow_unicode=True))
print("hermes_provider=custom")
print(f"hermes_model={model}")
print(f"hermes_pool_models_count={len(pool_models)}")
print(f"hermes_base_url={upstream_url}")
print("hermes_max_tokens=4096")
print("install_hermes=ok")
PY
}

verify_agents() {
  local stamp
  stamp="$(date +%Y%m%d%H%M%S)"
  "$HOME/.openclaw/bin/openclaw" agent \
    --local \
    --agent main \
    --session-key "agent:main:dogegate-verify-$stamp" \
    --model "openai/$MODEL" \
    --message "Reply with exactly: pong" \
    --timeout 180
  "$HOME/.local/bin/hermes" chat \
    -q "Use terminal to run: printf pong. Then answer with exactly the command output." \
    --ignore-rules \
    --toolsets hermes-cli \
    --quiet
}

open_openclaw_dashboard() {
  local openclaw_bin="$HOME/.openclaw/bin/openclaw"
  if [[ ! -x "$openclaw_bin" ]]; then
    openclaw_bin="$(command -v openclaw || true)"
  fi
  [[ -n "$openclaw_bin" && -x "$openclaw_bin" ]] || die "OpenClaw CLI not found"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "dry_run=true"
    echo "would_quit_openclaw_app=true"
    echo "would_restart_gateway=true"
    echo "would_wait_for_health=true"
    echo "would_open_dashboard=true"
    return
  fi

  osascript -e 'tell application "OpenClaw" to quit' >/dev/null 2>&1 || true
  sleep 1
  pkill -x OpenClaw >/dev/null 2>&1 || true

  "$openclaw_bin" gateway restart >/dev/null

  local ready=0
  local attempt
  for attempt in $(seq 1 45); do
    if "$openclaw_bin" gateway call health --json >/dev/null 2>&1; then
      ready=1
      break
    fi
    sleep 1
  done
  [[ "$ready" -eq 1 ]] || die "OpenClaw gateway did not become healthy within 45 seconds"

  "$openclaw_bin" dashboard --yes >/dev/null
  echo "openclaw_gateway=healthy"
  echo "openclaw_dashboard=opened"
}

inspect_antigravity() {
  need_cmd python3
  python3 - "$UPSTREAM_URL" <<'PY'
import json
import plistlib
import sys
import urllib.error
import urllib.request
from collections import Counter
from pathlib import Path
from urllib.parse import urljoin

upstream_url = sys.argv[1].rstrip("/")
home = Path.home()
config_path = home / ".antigravity_tools" / "gui_config.json"
app_info_path = Path("/Applications/Antigravity Tools.app/Contents/Info.plist")

def print_kv(key, value):
    print(f"{key}={value}")

if app_info_path.exists():
    try:
        info = plistlib.loads(app_info_path.read_bytes())
        print_kv("antigravity_tools_version", info.get("CFBundleShortVersionString", "unknown"))
    except Exception:
        print_kv("antigravity_tools_version", "unreadable")
else:
    print_kv("antigravity_tools_version", "not_installed")

if not config_path.exists():
    print_kv("config_found", "False")
    raise SystemExit(0)

data = json.loads(config_path.read_text())
proxy = data.get("proxy") or {}
cloudflared = data.get("cloudflared") or {}
print_kv("config_found", "True")
print_kv("config_path", str(config_path))
print_kv("proxy_port", proxy.get("port", ""))
print_kv("proxy_enabled", proxy.get("enabled", ""))
print_kv("proxy_auto_start", proxy.get("auto_start", ""))
print_kv("proxy_allow_lan_access", proxy.get("allow_lan_access", ""))
print_kv("proxy_auth_mode", proxy.get("auth_mode", ""))
print_kv("proxy_scheduling_mode", (proxy.get("scheduling") or {}).get("mode", ""))
print_kv("cloudflared_enabled", cloudflared.get("enabled", ""))
print_kv("cloudflared_mode", cloudflared.get("mode", ""))
print_kv("cloudflared_port", cloudflared.get("port", ""))

api_key = proxy.get("api_key") or ""
headers = {}
if api_key:
    headers["Authorization"] = f"Bearer {api_key}"

models_url = urljoin(upstream_url + "/", "models")
print_kv("models_url", models_url)
try:
    req = urllib.request.Request(models_url, headers=headers)
    with urllib.request.urlopen(req, timeout=15) as resp:
        payload = json.loads(resp.read().decode("utf-8"))
except urllib.error.HTTPError as exc:
    print_kv("models_query_ok", "False")
    print_kv("models_query_error", f"HTTP {exc.code}")
    raise SystemExit(0)
except Exception as exc:
    print_kv("models_query_ok", "False")
    print_kv("models_query_error", type(exc).__name__)
    raise SystemExit(0)

models = [item.get("id", "") for item in payload.get("data", []) if item.get("id")]
print_kv("models_query_ok", "True")
print_kv("model_count", len(models))

def family(model_id: str) -> str:
    for prefix in ("claude", "gemini", "gpt", "deepseek", "qwen", "grok"):
        if model_id.startswith(prefix):
            return prefix
    return "other"

counts = Counter(family(model_id) for model_id in models)
for name in sorted(counts):
    print_kv(f"model_family_{name}", counts[name])

for name in ("claude", "gemini", "gpt", "other"):
    selected = [m for m in models if family(m) == name]
    if selected:
        print(f"{name}_models_sample=" + ",".join(selected[:20]))
PY
}

case "$COMMAND" in
  install) install ;;
  install-openclaw) install_openclaw ;;
  install-hermes) install_hermes ;;
  verify) verify ;;
  verify-agents) verify_agents ;;
  open-openclaw-dashboard) open_openclaw_dashboard ;;
  inspect-antigravity) inspect_antigravity ;;
  doctor) doctor ;;
  *) die "unknown command: $COMMAND" ;;
esac
